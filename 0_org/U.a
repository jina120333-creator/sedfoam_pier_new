FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=64;scalar=64";
    class       volVectorField;
    location    "0";
    object      U.a;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    //inletWater
    "inletWater.*"
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    inletSediment
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    outletWater
    {
        type            zeroGradient;
//        type            fixedValue;
//        value           uniform (0 0 0);
    }
    outletSediment
    {
        //type            zeroGradient;
        type            fixedValue;
        value           uniform (0 0 0);
    }
    "(sideWalls|bottom|top|pier)"
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
}


// ************************************************************************* //
