FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      pa;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 1e-6;	//0;

boundaryField
{
    "(sideWalls|bottom|pier)"
    {
	type fixedValue;
        value uniform 0;
    }
    top
    {
        type            zeroGradient;
    }
    //inletWater
    "inletWater.*"
    {
        type            zeroGradient;
    }
    inletSediment
    {
        type            zeroGradient;
    }
    outletWater
    {
        type            zeroGradient;
    }
    outletSediment
    {
        type            zeroGradient;
    }

}


