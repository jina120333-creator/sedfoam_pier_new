FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "1";
    object      p_rbgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;	//0;

boundaryField
{
    "(sideWalls|bottom|pier)"
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }
    top
    {
        type            totalPressure;
        p0              uniform 0;
        value           uniform 0;
    }
    inletWater
    {
        type            zeroGradient;
    }
    inletSediment
    {
        type            zeroGradient;
    }
    outletWater
    {
//        type            zeroGradient;
        type            fixedValue;
        value           uniform 0;
    }
    outletSediment
    {
//        type            zeroGradient;
        type            fixedValue;
        value           uniform 0;
    }

}


