FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Time derivative schemes
ddtSchemes
{
    default         Euler;
}

// Gradient schemes
gradSchemes
{
    default         Gauss linear;
//    grad(k.b)         cellLimited Gauss linear 1;
//    grad(omega.b)     cellLimited Gauss linear 1;
//    grad(epsilon.b)   cellLimited Gauss linear 1;
}

// Divergence schemes
divSchemes
{
    default                         none;
// alphaEqn
    div(phi,alpha)  Gauss limitedLinear01 1; //Gauss upwind; //Gauss limitedLinear01 1; 
    div(phir,alpha) Gauss limitedLinear01 1; //Gauss upwind; //Gauss limitedLinear01 1; 
// UEqn
    div(phia,Ua)    Gauss linearUpwind grad(Ua);
    div(phib,Ub)    Gauss linearUpwind grad(Ub);
    div(phi.a,U.a)    Gauss upwind phi; //Gauss limitedLinearV 1;
    div(phi.b,U.b)    Gauss upwind phi; //Gauss limitedLinearV 1;
    div(phiRa,Ua)   Gauss linear; //Gauss upwind phi;
    div(phiRb,Ub)   Gauss linear; //Gauss upwind phi;
    div(Rca)        Gauss linear;
    div(Rcb)        Gauss linear;
// pEqn
    div(alpha,nu) Gauss linear;
// k and EpsilonEqn
    div(phi.b,k.b)       Gauss linearUpwind grad(k); //Gauss limitedLinear 1;
    div(phi.b,epsilon.b) Gauss linearUpwind grad(epsilon); //Gauss limitedLinear 1;
    div(phi.b,omega.b)   Gauss linearUpwind grad(omega); //Gauss limitedLinear 1;
// alphaPlastic
    div(phia,alphaPlastic)    Gauss upwind; //Gauss limitedLinear01 1;
// pa
    div(phia,pa_new_value)    Gauss upwind; //Gauss limitedLinear 1;
// ThetaEqn
    div(phi,Theta)       Gauss limitedLinear 1;
}

